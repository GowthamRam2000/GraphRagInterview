APP_ENV: "cloud"
STORE_BACKEND: "sql"
GRAPH_STORE_BACKEND: "neo4j"
CORS_ALLOWED_ORIGINS: "https://FRONTEND_SERVICE_URL"
DATABASE_URL: "postgresql+asyncpg://DB_USER:DB_PASSWORD@/graphrag?host=/cloudsql/PROJECT:REGION:INSTANCE"
NEO4J_URI: "neo4j+s://YOUR_AURA_HOST.databases.neo4j.io"
NEO4J_USERNAME: "neo4j"
GCS_BUCKET_RAW: "YOUR_RAW_BUCKET"
GCS_BUCKET_ARTIFACTS: "YOUR_ARTIFACT_BUCKET"
GCP_PROJECT_ID: "YOUR_PROJECT_ID"
GCP_REGION: "us-central1"
PARSER_PRIMARY: "llamaparse"
PARSER_FALLBACK: "liteparse"
LLAMAPARSE_TIER: "agentic"
LLAMAPARSE_RESULT_TYPE: "markdown"
LITEPARSE_OCR_ENABLED: "false"
LITEPARSE_DPI: "150"
ROUTER_MODEL: "gpt-5.4-mini"
EXTRACTOR_MODEL: "gpt-5.4-mini"
ANSWER_MODEL: "gpt-5.4-mini"
GREETING_MODEL: "gpt-5.4-mini"
LLM_ANSWER_ENABLED: "true"
ROUTER_REASONING_EFFORT: "none"
ANSWER_REASONING_EFFORT: "low"
EXTRACTOR_REASONING_EFFORT: "low"
PROMPT_CACHE_NAMESPACE: "cognizinterview-graphrag-v1"
ANSWER_MAX_OUTPUT_TOKENS: "900"
EMBEDDING_PROVIDER: "gemini_api"
EMBEDDING_MODEL: "gemini-embedding-2"
EMBEDDING_DIMENSION: "1536"
EMBEDDING_TASK_TYPE: "RETRIEVAL_DOCUMENT"
RERANK_PROVIDER: "vertex"
RERANK_MODEL: "semantic-ranker-default-004"
RERANK_LOCATION: "global"
RERANK_TOP_N: "8"
RERANK_CANDIDATE_LIMIT: "40"
