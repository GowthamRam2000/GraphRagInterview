# Runtime mode: local for development, cloud for Cloud Run.
APP_ENV=local

# API auth. Frontend uses NEXT_PUBLIC_DEMO_API_KEY for the demo header, backend checks API_AUTH_KEY.
API_AUTH_KEY=replace-with-random-demo-key
NEXT_PUBLIC_DEMO_API_KEY=replace-with-same-demo-key-for-demo-only

# Persistence. Use GRAPH_STORE_BACKEND=sql when Neo4j Aura is paused.
STORE_BACKEND=sql
GRAPH_STORE_BACKEND=sql
DATABASE_URL=postgresql+asyncpg://graphrag_app:replace-password@127.0.0.1:5432/graphrag
DATABASE_URL_CLOUD_RUN=postgresql+asyncpg://graphrag_app:replace-password@/graphrag?host=/cloudsql/project:region:instance
DB_NAME=graphrag
DB_USER=graphrag_app
DB_PASSWORD=replace-cloud-sql-password
CLOUD_SQL_INSTANCE_CONNECTION_NAME=project:region:instance

# Neo4j Aura or local Neo4j.
NEO4J_URI=neo4j+s://replace.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=replace-neo4j-password

# Google Cloud.
GCP_PROJECT_ID=replace-project-id
GCP_REGION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/local-service-account.json
GCS_BUCKET_RAW=replace-raw-pdf-bucket
GCS_BUCKET_ARTIFACTS=replace-artifact-bucket
CORS_ALLOWED_ORIGINS=

# LlamaParse primary parser and LiteParse fallback.
PARSER_PRIMARY=llamaparse
PARSER_FALLBACK=liteparse
LLAMA_CLOUD_API_KEY=replace-llamacloud-key
LLAMAPARSE_TIER=agentic
LLAMAPARSE_RESULT_TYPE=markdown
LITEPARSE_OCR_ENABLED=false
LITEPARSE_DPI=150

# Models and providers.
OPENAI_API_KEY=replace-openai-key
GEMINI_API_KEY=replace-gemini-key
ROUTER_MODEL=gpt-5.4-mini
EXTRACTOR_MODEL=gpt-5.4-mini
ANSWER_MODEL=gpt-5.4-mini
GREETING_MODEL=gpt-5.4-mini
LLM_ANSWER_ENABLED=true
ROUTER_REASONING_EFFORT=none
ANSWER_REASONING_EFFORT=low
EXTRACTOR_REASONING_EFFORT=low
PROMPT_CACHE_NAMESPACE=cognizinterview-graphrag-v1
ANSWER_MAX_OUTPUT_TOKENS=900

# Embeddings and reranking.
EMBEDDING_PROVIDER=gemini_api
EMBEDDING_MODEL=gemini-embedding-2
EMBEDDING_DIMENSION=1536
EMBEDDING_TASK_TYPE=RETRIEVAL_DOCUMENT
RERANK_PROVIDER=vertex
RERANK_MODEL=semantic-ranker-default-004
RERANK_LOCATION=global
RERANK_TOP_N=8
RERANK_CANDIDATE_LIMIT=40

# Frontend.
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000

# Optional Cloud Run deploy overrides.
REPOSITORY=cognizinterview
BACKEND_SERVICE=cogniz-graphrag-api
FRONTEND_SERVICE=cogniz-graphrag-web
RUN_SERVICE_ACCOUNT=
TAG=
CLOUD_RUN_GRAPH_STORE_BACKEND=sql
